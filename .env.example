# =========================================================================
# OpenGoo! Monorepo Environment Variables Example
# Copy this file to '.env' and fill in your custom configurations.
# =========================================================================

# 🌐 Google Cloud Platform (GCP) Deployment Configurations
# Used by deployment scripts (deploy-teacher.sh, deploy-student.sh)
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-east2

# 🔥 Firebase Client SDK Credentials
# These will be automatically populated for you if you run './setup-firebase.sh'.
# Alternatively, you can copy them from your Firebase Console (Project Settings > Web App).
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-gcp-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-gcp-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-gcp-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIRESTORE_DATABASE_ID=opengoo
