rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Match any document in the quizzes collection (saved quiz sets)
    match /quizzes/{quizId} {
      // READ ACCESS: Allow if system default, OR current user is the creator, OR current user is in sharedWith
      allow read: if resource.data.isSystemDefault == true || 
                   resource.data.creator == request.auth.token.email || 
                   request.auth.token.email in resource.data.sharedWith;
      
      // CREATE ACCESS: Allow if setting themselves as creator
      allow create: if request.resource.data.creator == request.auth.token.email;
      
      // UPDATE ACCESS: Only the original creator can edit fields (such as quiz content or sharedWith list)
      allow update: if resource.data.creator == request.auth.token.email && 
                     request.resource.data.creator == request.auth.token.email;
                     
      // DELETE ACCESS: Only the original creator can delete
      allow delete: if resource.data.creator == request.auth.token.email;
    }
    
    // Match any document in the sessions collection (active game rooms)
    match /sessions/{pin} {
      allow read, write: if true;
      
      // Match any document in the answers subcollection (submitted player choices)
      match /answers/{playerId} {
        allow read, write: if true;
      }
    }
    
  }
}
