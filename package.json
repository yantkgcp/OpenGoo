{
  "name": "opengoo-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:core": "npm run build --workspace=packages/core",
    "build:teacher": "npm run build --workspace=packages/teacher-app",
    "build:student": "npm run build --workspace=packages/student-app",
    "build:all": "npm run build --workspace=packages/core && npm run build --workspace=packages/teacher-app && npm run build --workspace=packages/student-app",
    "dev:teacher": "npm run dev --workspace=packages/teacher-app",
    "dev:student": "npm run dev --workspace=packages/student-app"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "firebase": "^12.15.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
